# ── CVDP Agent Harness Configuration ──────────────────────────────────────────
#
# OPENAI_USER_KEY is not used by our agent (we use Codex CLI).
# The harness references it for LLM-based subjective scoring only.
# We disable subjective scoring since our benchmark uses iverilog pass/fail.
#
ENABLE_SUBJECTIVE_SCORING=false

# Docker image used for OSS simulation (iverilog + vvp inside harness)
OSS_SIM_IMAGE=ghcr.io/hdl/sim/osvb

# Benchmark output directory
BENCHMARK_PREFIX=work

# Parallelism (1 = sequential, safe default)
BENCHMARK_THREADS=1

# Docker timeouts (seconds)
DOCKER_TIMEOUT=600
DOCKER_TIMEOUT_AGENT=900
